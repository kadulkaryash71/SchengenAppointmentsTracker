# Target page. Leave TARGET_URL blank to build it from CITY_SLUG + VISA_TYPE.
CITY_SLUG=dublin
VISA_TYPE=tourism
TARGET_URL=

# Optional comma-separated filter. Leave blank to notify for any available country on that page.
COUNTRIES=Iceland,Netherlands,Denmark

# Email delivery via SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com

# Optional settings.
STATE_FILE=.state/schengen_state.json
ALWAYS_NOTIFY=false
SAVE_EMPTY_STATE=false
LOG_LEVEL=INFO
